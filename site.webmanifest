{
  "name": "TapStudio Pro",
  "short_name": "TapStudio",
  "start_url": ".",
  "display": "standalone",
  "background_color": "#0d1117",
  "theme_color": "#0d1117",
  "icons": [
    {
      "src": "icon.ico",
      "sizes": "256x256",
      "type": "image/x-icon"
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "application/x-tapstudio-project": [".tsp"]
      }
    }
  ]
}
